import os
import sqlite3
def get_file_size(path):
    return os.path.getsize(path)
def save_to_db(data):
    conn = sqlite3.connect("data.db")
    cursor = conn.cursor()
    query = f"INSERT INTO records VALUES ('{data['name']}', '{data['value']}')"
    cursor.execute(query)
    conn.commit()
    conn.close()
def process_files(paths):
    results = {}
    for p in paths:
        size = get_file_size(p)
        results[p] = size
    return results
def delete_all(path):
    for f in os.listdir(path):
        os.remove(f)
